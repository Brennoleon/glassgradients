selector: .engine-up-card
preset: editor
recipe: panel
effect: liquid
performance: auto
mainFilter: standard

engineUp:
  enabled: true
  duration: 14s
  easing: ease-in-out
  x: 4%
  y: 2%
  scale: 1.08
  blur: 24
  brightness: 112%

motionBlurrin:
  layers:
    - count: 6
      minSize: 40
      maxSize: 90
      speed: 0.6
      direction: right
    - count: 10
      minSize: 12
      maxSize: 36
      speed: 1.1
      direction: diagonal
  blur: 20
  openness: 0.4
  edgeFade: 0.2

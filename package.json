{
  "name": "glassgradients",
  "version": "1.2.0",
  "description": "LTS glass surface engine with surface, gradient, frost, recipes, responsive variants, theme tokens, static CSS compilation, and optional runtime motion.",
  "type": "module",
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    },
    "./parser": {
      "types": "./src/parser.d.ts",
      "default": "./src/parser.js"
    },
    "./compiler": {
      "types": "./src/compiler.d.ts",
      "default": "./src/compiler.js"
    },
    "./runtime": {
      "types": "./src/runtime.d.ts",
      "default": "./src/runtime.js"
    },
    "./defaults": {
      "types": "./src/defaults.d.ts",
      "default": "./src/defaults.js"
    },
    "./theme": {
      "types": "./src/theme.d.ts",
      "default": "./src/theme.js"
    },
    "./variants": {
      "types": "./src/variants.d.ts",
      "default": "./src/variants.js"
    },
    "./components": {
      "types": "./src/components.d.ts",
      "default": "./src/components.js"
    },
    "./components/react": {
      "types": "./src/components/react.d.ts",
      "default": "./src/components/react.js"
    },
    "./components/preact": {
      "types": "./src/components/preact.d.ts",
      "default": "./src/components/preact.js"
    },
    "./adapters/react": {
      "types": "./src/adapters/react.d.ts",
      "default": "./src/adapters/react.js"
    },
    "./adapters/vue": {
      "types": "./src/adapters/vue.d.ts",
      "default": "./src/adapters/vue.js"
    },
    "./adapters/solid": {
      "types": "./src/adapters/solid.d.ts",
      "default": "./src/adapters/solid.js"
    },
    "./adapters/preact": {
      "types": "./src/adapters/preact.d.ts",
      "default": "./src/adapters/preact.js"
    },
    "./adapters/svelte": {
      "types": "./src/adapters/svelte.d.ts",
      "default": "./src/adapters/svelte.js"
    },
    "./adapters/tailwind": {
      "types": "./src/adapters/tailwind.d.ts",
      "default": "./src/adapters/tailwind.js"
    },
    "./adapters/shadcn": {
      "types": "./src/adapters/shadcn.d.ts",
      "default": "./src/adapters/shadcn.js"
    },
    "./adapters/unocss": {
      "types": "./src/adapters/unocss.d.ts",
      "default": "./src/adapters/unocss.js"
    },
    "./adapters/next": {
      "types": "./src/adapters/next.d.ts",
      "default": "./src/adapters/next.js"
    },
    "./adapters/nuxt": {
      "types": "./src/adapters/nuxt.d.ts",
      "default": "./src/adapters/nuxt.js"
    },
    "./adapters/astro": {
      "types": "./src/adapters/astro.d.ts",
      "default": "./src/adapters/astro.js"
    },
    "./adapters/vanilla": {
      "types": "./src/adapters/vanilla.d.ts",
      "default": "./src/adapters/vanilla.js"
    }
  },
  "bin": {
    "glassgradients": "src/cli.js"
  },
  "files": [
    "src",
    "docs",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "examples"
  ],
  "scripts": {
    "test": "node --test",
    "build": "node ./src/cli.js --help",
    "metrics": "node ./scripts/generate-metrics.mjs",
    "site:build": "npm run metrics && node ./scripts/build-site.mjs",
    "release:check": "npm run site:build && npm test && npm run build && npm pack --dry-run",
    "bench": "node ./scripts/benchmark.mjs"
  },
  "keywords": [
    "glassmorphism",
    "gradient",
    "glass",
    "frosted-glass",
    "mesh-gradient",
    "aurora",
    "backdrop-filter",
    "theme",
    "tokens",
    "ssr",
    "responsive",
    "effects",
    "lts",
    "stable",
    "visual",
    "animation",
    "performance",
    "worker",
    "css",
    "runtime",
    "compiler",
    "web",
    "ui",
    "components",
    "component-library",
    "react",
    "vue",
    "solid",
    "preact",
    "tailwindcss",
    "tailwind-v4",
    "shadcn",
    "unocss",
    "adaptive",
    "monitoring",
    "motion-blur",
    "liquid-glass",
    "nextjs",
    "nuxt",
    "astro",
    "svelte",
    "adapter",
    "framework-agnostic"
  ],
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Brennoleon/glassgradients.git"
  },
  "bugs": {
    "url": "https://github.com/Brennoleon/glassgradients/issues"
  },
  "homepage": "https://github.com/Brennoleon/glassgradients#readme",
  "peerDependencies": {
    "preact": ">=10.19",
    "react": ">=18",
    "solid-js": ">=1.8",
    "vue": ">=3.3"
  },
  "peerDependenciesMeta": {
    "preact": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  }
}
